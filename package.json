{
  "name": "@stadiumops/world-cup-2026-copilot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:web-component": "rollup -c rollup.digital-twin.config.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "playwright test",
    "lint": "eslint . --max-warnings=0",
    "format": "echo 'Prettier removed'",
    "bundle": "esbuild tests/regression/run-fixtures.ts --bundle --platform=node --format=esm --outfile=dist/regression-runner.mjs",
    "audit:deps": "pnpm audit --audit-level=moderate",
    "perf": "lhci autorun --config=perf/lighthouserc.cjs"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0",
    "@protobuf-ts/runtime": "2.9.4",
    "@solid-primitives/storage": "4.3.1",
    "@solidjs/router": "0.15.3",
    "@tanstack/solid-virtual": "3.13.12",
    "@zxing/text-encoding": "0.9.0",
    "comlink": "4.4.2",
    "date-fns": "4.1.0",
    "idb": "8.0.2",
    "jose": "5.9.6",
    "msgpackr": "1.11.2",
    "pino": "9.6.0",
    "solid-js": "1.9.5",
    "uuid": "11.1.0",
    "zod": "3.24.1",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@eslint/js": "9.18.0",
    "@lhci/cli": "0.14.0",
    "@playwright/test": "1.55.1",
    "@rollup/plugin-node-resolve": "15.3.1",
    "@testing-library/jest-dom": "6.6.3",
    "@types/node": "22.10.5",
    "@typescript-eslint/eslint-plugin": "8.20.0",
    "@typescript-eslint/parser": "8.20.0",
    "@vitest/coverage-v8": "3.2.6",
    "@vitejs/plugin-basic-ssl": "1.2.0",
    "c8": "10.1.3",
    "esbuild": "0.25.10",
    "eslint": "9.18.0",
    "fast-check": "3.23.2",
    "jsdom": "25.0.1",
    "rollup": "4.59.0",
    "typescript": "5.7.3",
    "vite": "6.4.3",
    "vite-plugin-solid": "2.11.0",
    "vitest": "3.2.6"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.10",
      "rollup": "4.59.0",
      "tmp": "0.2.6",
      "vite": "6.4.3"
    }
  }
}
