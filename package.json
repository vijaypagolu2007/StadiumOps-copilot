{
  "name": "@stadiumops/world-cup-2026-copilot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract"
    ]
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --configLoader runner",
    "build": "vite build --configLoader runner",
    "preview": "vite preview --configLoader runner",
    "build:web-component": "rollup -c rollup.digital-twin.config.mjs",
    "test": "vitest run --coverage --configLoader runner",
    "test:watch": "vitest",
    "test:integration": "playwright test",
    "lint": "eslint . --max-warnings=0",
    "format": "echo 'Prettier removed'",
    "bundle": "esbuild tests/regression/run-fixtures.ts --bundle --platform=node --format=esm --outfile=dist/regression-runner.mjs",
    "audit:deps": "pnpm audit --audit-level=moderate",
    "perf": "lhci autorun --config=perf/lighthouserc.cjs"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0",
    "@protobuf-ts/runtime": "2.9.4",
    "@solid-primitives/storage": "4.3.1",
    "@solidjs/router": "0.15.3",
    "@tanstack/solid-virtual": "3.13.12",
    "@zxing/text-encoding": "0.9.0",
    "comlink": "4.4.2",
    "date-fns": "4.1.0",
    "idb": "8.0.2",
    "jose": "5.9.6",
    "msgpackr": "1.11.2",
    "pino": "9.6.0",
    "solid-js": "1.9.5",
    "uuid": "11.1.1",
    "zod": "3.24.1",
    "zustand": "5.0.3"
  },
